# Ollama is local and keyless — this recipe needs NO API key and no .env file.
#
# Optional: point at a non-default Ollama server (the ollama client reads this
# natively). Leave unset to use the local default (http://localhost:11434).
# OLLAMA_HOST=http://localhost:11434
#
# Optional: the env twin of Part B's kill switch — any truthy value disables
# all Bir recording process-wide. The lesson overrides it with an explicit
# configure(enabled=True) so its checks stay deterministic.
# BIR_DISABLED=1
